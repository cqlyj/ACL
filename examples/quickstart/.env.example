# =============================================================================
#  ACL quickstart — minimal CLI demo
#
#  Copy this file to `.env` and fill in the four private keys. Generate
#  fresh ones with `cast wallet new` (each role gets its own EOA), then
#  fund them per the table in the top-level README (CLIENT needs A0GI +
#  tUSDC, PROVIDER needs A0GI, EVALUATOR_OPERATOR needs ≥3 OG).
# =============================================================================

# --- chain RPCs --------------------------------------------------------------
GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
# Sepolia is only used for ENS CCIP-Read. Leave blank to use the SDK default
# (PublicNode); supply your own for higher quotas.
SEPOLIA_RPC_URL=

# --- agent keys (one EOA per role) -------------------------------------------
CLIENT_PRIVATE_KEY=0x...
PROVIDER_PRIVATE_KEY=0x...
EVALUATOR_OPERATOR_PRIVATE_KEY=0x...
# Optional. When set, src/evaluator.ts auto-authorises the operator on
# `ACLEvaluator` via `setOperator(operator, true)`. Set to the
# private key of the address that owns ACLEvaluator (NB: this is the
# `EVALUATOR_PRIVATE_KEY` from the root .env on testnet — the
# constructor seeds the owner from `EVALUATOR_OWNER`, NOT the deployer).
# A fresh user without that admin key cannot run the evaluator against
# the live testnet ACLEvaluator deployment; ask the project to authorise
# your operator EOA, or fork + redeploy with `make deploy-0g`.
EVALUATOR_OWNER_PRIVATE_KEY=

# --- ENS sub-label this provider publishes under ($LABEL.acl.eth) ------------
# Pick something globally unique; the gateway indexer matches by substring
# inclusion on `acl.task-domains`, so a too-generic label can collide
# with other registered demos.
PROVIDER_ENS_LABEL=quickstart-greeter

# --- 0G Compute LLM backend (OpenAI-compatible) ------------------------------
#
# Used by ClientAgent + ProviderAgent for their LLM reasoning calls.
# (The EvaluatorAgent does NOT use this; it talks to `@0glabs/0g-serving-broker`
# directly under EVALUATOR_OPERATOR_PRIVATE_KEY's ledger so the raw TEE
# signature is captured for on-chain settlement.)
#
# Two paths work:
#
# 1. ROUTER (https://router.0g.ai/v1) — recommended for the quickstart.
#    Get a free API key from https://pc.0g.ai → API Keys.
#       ZG_ROUTER_API_KEY=sk-...
#       ZG_ROUTER_MODEL=qwen-2.5-7b-instruct
#       # leave ZG_ROUTER_BASE_URL empty (defaults to the router)
#
# 2. DIRECT — CLI-mintable per-provider key:
#       0g-compute-cli inference acknowledge-provider \
#         --provider 0xa48f01287233509FD694a22Bf840225062E67836
#       0g-compute-cli inference get-secret \
#         --provider 0xa48f01287233509FD694a22Bf840225062E67836 --duration 0
#    Then set:
#       ZG_ROUTER_API_KEY=app-sk-...
#       ZG_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct
#       ZG_ROUTER_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
ZG_ROUTER_API_KEY=
ZG_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct
ZG_ROUTER_BASE_URL=

# --- ACL gateway URL ---------------------------------------------------------
# Any reachable @acl/gateway instance (the one started by `make
# quickstart-gateway` works). NB: this is the discovery-API base URL
# (`<base>/agents`); the CCIP-Read URL template lives on chain in
# `ACLOffchainResolver.url` and is a separate concern.
GATEWAY_URL=http://localhost:3000

# --- AXL Go binary (`go build -o node ./cmd/node/`) --------------------------
# Default points at the binary built by `make axl-setup` from the repo root.
AXL_BIN=../../axl/node
