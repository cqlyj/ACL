# =============================================================================
#  ACL quickstart — minimal CLI demo
#
#  Copy this file to `.env` and fill in the four private keys. The four EOAs
#  funded by `make register-agent` (root .env) work out of the box; you can
#  reuse those.
# =============================================================================

# --- chain RPCs ---------------------------------------------------------------
GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
SEPOLIA_RPC_URL=

# --- agent keys (one EOA per role) -------------------------------------------
CLIENT_PRIVATE_KEY=0x...
PROVIDER_PRIVATE_KEY=0x...
EVALUATOR_OPERATOR_PRIVATE_KEY=0x...
# Optional. When set, src/setup.ts auto-authorises the operator on
# ACLEvaluator (`setOperator`). Set to the address that owns ACLEvaluator
# (same as DEPLOYER_PRIVATE_KEY from the root .env on testnet).
EVALUATOR_OWNER_PRIVATE_KEY=

# --- ENS sub-label this provider publishes under ($LABEL.acl.eth) ------------
PROVIDER_ENS_LABEL=quickstart-greeter

# --- 0G Compute LLM backend (OpenAI-compatible) ------------------------------
# Two paths work — the testnet "router" (https://router.0g.ai/v1, API key from
# https://pc.0g.ai → API Keys) or the CLI-mintable "direct" provider.
# Direct example (used by examples/kelp-postmortem):
#   ZG_ROUTER_API_KEY=app-sk-...
#   ZG_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct
#   ZG_ROUTER_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
ZG_ROUTER_API_KEY=
ZG_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct
ZG_ROUTER_BASE_URL=

# --- ACL gateway URL ---------------------------------------------------------
# Any reachable @acl/gateway instance (the one started by `make gateway` works).
GATEWAY_URL=http://localhost:3000

# --- AXL Go binary (`go build -o node ./cmd/node/`) --------------------------
# Default points at the binary built by `make axl-setup` from the repo root.
AXL_BIN=../../axl/node
