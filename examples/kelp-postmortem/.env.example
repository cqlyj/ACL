# --------------------------------------------------------------------
# Galileo + ENS RPCs
# --------------------------------------------------------------------
GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
SEPOLIA_RPC_URL=

# --------------------------------------------------------------------
# Agent keys (each agent uses its own EOA so on-chain identity is clean)
# --------------------------------------------------------------------
CLIENT_PRIVATE_KEY=0x...
PROVIDER_SECURITY_PRIVATE_KEY=0x...
PROVIDER_GENERALIST_PRIVATE_KEY=0x...
EVALUATOR_OPERATOR_PRIVATE_KEY=0x...
EVALUATOR_OWNER_PRIVATE_KEY=0x...

# --------------------------------------------------------------------
# Pre-registered ENS sub-labels under acl.eth (run scripts/register-providers.ts to mint them)
# --------------------------------------------------------------------
PROVIDER_SECURITY_ENS_LABEL=kelp-security
PROVIDER_GENERALIST_ENS_LABEL=kelp-generalist

# --------------------------------------------------------------------
# 0G Compute (HTTP backend for ClientAgent + ProviderAgent reasoning).
#
# Two paths work, both OpenAI-compatible:
#
# 1. ROUTER (https://router.0g.ai/v1) — recommended for production.
#    API key is created in the web UI (https://pc.0g.ai → API Keys).
#       ZG_ROUTER_API_KEY=sk-...
#       ZG_ROUTER_MODEL=qwen-2.5-7b-instruct
#       # ZG_ROUTER_BASE_URL=  (leave blank — defaults to the router)
#
# 2. DIRECT (any 0G Compute provider's /v1/proxy endpoint) — what we
#    use here because it's CLI-mintable. Generate with:
#       0g-compute-cli inference acknowledge-provider \
#         --provider 0xa48f01287233509FD694a22Bf840225062E67836
#       0g-compute-cli inference get-secret \
#         --provider 0xa48f01287233509FD694a22Bf840225062E67836 \
#         --duration 0
#    Then set:
#       ZG_ROUTER_API_KEY=app-sk-...        # the secret printed by get-secret
#       ZG_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct
#       ZG_ROUTER_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
#
# The EvaluatorAgent does NOT use this; it talks to the broker SDK
# directly under the EVALUATOR_OPERATOR_PRIVATE_KEY's ledger so the
# raw TEE signature is captured for on-chain settlement.
# --------------------------------------------------------------------
ZG_ROUTER_API_KEY=app-sk-...
ZG_ROUTER_MODEL=qwen/qwen-2.5-7b-instruct
ZG_ROUTER_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy

# --------------------------------------------------------------------
# Gateway URL (any reachable @acl/gateway instance — the public testnet
# gateway works fine; ngrok one is fine too).
# --------------------------------------------------------------------
GATEWAY_URL=https://gateway.acl.example

# --------------------------------------------------------------------
# Coordinator HTTP listen port
# --------------------------------------------------------------------
PORT=8787

# --------------------------------------------------------------------
# AXL bridges (auto-spawned).
#
# `make axl-setup` (run once from the repo root) builds the AXL Go
# binary into `axl/node`, so the relative path below works straight
# out of `examples/kelp-postmortem` without copying or symlinking.
# Override with an absolute path (recommended on CI / Docker) or with
# `./node` if you've manually dropped the binary alongside this file.
#
# IMPORTANT: keep the leading `./` or `../`. The Gensyn AXL binary is
# literally named `node` (`go build -o node ./cmd/node/`), which
# collides with Node.js on most operator $PATH layouts. The leading
# path component forces the relative-path resolution and stops the
# coordinator from accidentally booting Node.js against a JSON config.
# --------------------------------------------------------------------
AXL_BIN=../../axl/node

# --------------------------------------------------------------------
# Source material (filled in by scripts/upload-source.ts)
# --------------------------------------------------------------------
KELP_SOURCE_ROOT=

# --------------------------------------------------------------------
# Flow 2 — iNFT Commerce
# --------------------------------------------------------------------
# Demo oracle EOA. The same address MUST be authorised on
# `TrustedPartyVerifier` (the contract's `authorizedOracle` storage
# slot). The verifier exposes a single setter, `setOracle(address)`
# — there is no `setAuthorizedOracle`. Run as the verifier owner:
#   cast send $TRUSTED_PARTY_VERIFIER 'setOracle(address)' $DEMO_ORACLE_ADDRESS
# (owner-only) instead of redeploying. `RedeployEvaluator.s.sol` only
# redeploys ACLEvaluator and is NOT the right tool for this.
DEMO_ORACLE_PRIVATE_KEY=0x...

