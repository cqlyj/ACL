# =============================================================================
#  ACL — Agentic Commerce Verification Layer
#  Environment Variables
#
#  HOW TO USE
#    1. cp .env.example .env
#    2. Fill in ONLY the private keys + addresses in Section 1.
#    3. make deploy-0g       writes .env.deployed.0g
#    4. make deploy-sepolia  writes .env.deployed.sepolia
#    5. make merge-env       merges the deployed addresses back into .env.
#    6. make register-agent  registers the demo agent and mints test USDC.
#  You need 4 separate keys (DEPLOYER, EVALUATOR, CLIENT, PROVIDER). Reusing
#  the same key on testnet is fine; separate keys are recommended.
# =============================================================================

# -----------------------------------------------------------------------------
#  SECTION 1: MANUAL — keys + derived addresses
# -----------------------------------------------------------------------------

# DEPLOYER: deploys all contracts. Becomes owner of AgenticCommerce,
# TrustedPartyVerifier, ACLAgentNFT, ACLOffchainResolver.
# Needs ~0.5 A0GI on 0G Galileo (https://faucet.0g.ai) and ~0.1 ETH on Sepolia.
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# EVALUATOR OWNER: owner of ACLEvaluator. Authorises evaluation operators.
# Can equal DEPLOYER on testnet. Needs ~0.01 A0GI to call settle().
EVALUATOR_PRIVATE_KEY=0x...
EVALUATOR_OWNER=0x...

# CLIENT: simulates the buyer agent (creates jobs, funds escrow).
# RegisterAgent mints 10,000 tUSDC to this address.
CLIENT_PRIVATE_KEY=0x...
CLIENT_ADDRESS=0x...

# PROVIDER: simulates the provider agent (submits deliverables, gets paid).
# RegisterAgent mints 10,000 tUSDC to this address.
PROVIDER_PRIVATE_KEY=0x...
PROVIDER_ADDRESS=0x...

# ORACLE: ERC-7857 TrustedParty oracle. Signs re-encryption proofs off-chain.
# In production this key lives in a 0G TeeML enclave; for demo it is an EOA.
ORACLE_PRIVATE_KEY=0x...
ORACLE_ADDRESS=0x...

# Platform treasury: receives platform fees (if PLATFORM_FEE_BPS > 0).
PLATFORM_TREASURY=0x...
PLATFORM_FEE_BPS=0

# ENS owner of acl.eth on Sepolia (used once by SetupENS).
ENS_OWNER_PRIVATE_KEY=0x...
ENS_OWNER_ADDRESS=0x...

# CCIP-Read gateway: serves *.acl.eth lookups by reading the IdentityRegistry
# on 0G Galileo and signing the EIP-3668 response.
GATEWAY_URL=http://localhost:3000/{sender}/{data}.json
GATEWAY_SIGNER_PRIVATE_KEY=0x...
GATEWAY_SIGNER_ADDRESS=0x...
GATEWAY_PORT=3000

# Etherscan API key (Sepolia verification only).
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
#  SECTION 2: AUTOMATIC — filled by deployment scripts
# -----------------------------------------------------------------------------

# 0G Galileo deployed contracts
ACL_TEST_USDC=0x...
AGENTIC_COMMERCE=0x...
ACL_EVALUATOR=0x...
ACL_IDENTITY_REGISTRY=0x...
ACL_REPUTATION_REGISTRY=0x...
ACL_VALIDATION_REGISTRY=0x...
TRUSTED_PARTY_VERIFIER=0x...
ACL_AGENT_NFT=0x...
REPUTATION_HOOK=0x...
INFT_DELIVERY_HOOK=0x...

# Sepolia deployed contracts
ACL_OFFCHAIN_RESOLVER=0x...

# Auto-filled by RegisterAgent / SetAgentMetadata
PROVIDER_AGENT_ID=1
# ENS sub-label under the parent ACL ENS name (e.g. "researcher" for
# researcher.acl.eth). The CCIP-Read gateway indexes this value off
# `MetadataSet` events on the IdentityRegistry to map sub-names to agentIds.
PROVIDER_ENS_LABEL=researcher
# tokenURI for the agent NFT. SetAgentMetadata generates it as a
# `data:application/json;base64,...` URL so the artefact is self-contained.
PROVIDER_AGENT_URI=

# -----------------------------------------------------------------------------
#  SECTION 3: CONSTANTS — do not edit unless you know what you are doing
# -----------------------------------------------------------------------------

# 0G Galileo (chain ID 16602)
ZG_RPC=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZG_STORAGE_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# Sepolia (chain ID 11155111)
SEPOLIA_RPC=https://rpc.sepolia.org
SEPOLIA_CHAIN_ID=11155111

# ENS Sepolia canonical addresses
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_NAME_WRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8
ENS_PUBLIC_RESOLVER=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
ENS_UNIVERSAL_RESOLVER=0xeEeEEEeE14D718C2B47D9923Deab1335E144EeEe
ENS_PARENT_NAME=acl.eth

# AXL nodes (see axl/configs/*.json)
AXL_NODE_A_PORT=9002
AXL_NODE_B_PORT=9012
# Provider's full AXL Ed25519 public key (32 bytes hex, no 0x). Read from the
# running node's GET /topology endpoint. Stored on-chain as the
# `acl.axl-peer-id` metadata key by SetAgentMetadata.
PROVIDER_AXL_PEER_ID=
