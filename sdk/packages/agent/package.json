{
  "name": "@acl/agent",
  "version": "0.1.0",
  "description": "Umbrella package for the ACL SDK: re-exports the protocol primitives plus a chain-wiring kernel (createAgentRuntime) so a consumer can bootstrap an ACL agent in one import.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./runtime": "./src/runtime.ts"
  },
  "bin": {
    "acl-axl": "./bin/acl-axl.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b",
    "test": "bun test src"
  },
  "dependencies": {
    "@acl/core": "workspace:*",
    "@acl/discovery": "workspace:*",
    "@acl/evaluation": "workspace:*",
    "@acl/inft": "workspace:*",
    "@acl/negotiation": "workspace:*",
    "@acl/settlement": "workspace:*",
    "@acl/storage": "workspace:*",
    "ethers": "^6.13.4",
    "viem": "^2.21.0"
  }
}
