{
  "name": "@acl/gateway",
  "version": "0.1.0",
  "description": "ACL CCIP-Read gateway: serves ENSIP-10 wildcard records for *.acl.eth from on-chain ACL registries.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "bin": {
    "acl-gateway": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/cli.ts",
    "start": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b",
    "test": "bun test src"
  },
  "dependencies": {
    "@acl/core": "workspace:*",
    "hono": "^4.12.14",
    "viem": "^2.21.0"
  }
}
